# Nginx configuration for nodes-back.enclave-hq.com
# This file should be placed in /etc/nginx/sites-available/nodes-back.enclave-hq.com
# and symlinked to /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name nodes-back.enclave-hq.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name nodes-back.enclave-hq.com;

    # SSL certificates (managed by Certbot)
    ssl_certificate /etc/letsencrypt/live/nodes-back.enclave-hq.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nodes-back.enclave-hq.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Logging
    access_log /var/log/nginx/nodes-back.enclave-hq.com.access.log;
    error_log /var/log/nginx/nodes-back.enclave-hq.com.error.log;

    # CORS configuration snippet (create this file separately)
    # /etc/nginx/snippets/cors-backend.conf
    # add_header 'Access-Control-Allow-Origin' 'https://nodes.enclave-hq.com' always;
    # add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD' always;
    # add_header 'Access-Control-Allow-Headers' 'Origin, Content-Type, Content-Length, Accept-Encoding, X-CSRF-Token, Authorization, Cache-Control, Accept' always;
    # add_header 'Access-Control-Allow-Credentials' 'true' always;
    # add_header 'Access-Control-Expose-Headers' 'Content-Length, Content-Type, Authorization' always;

    # Handle OPTIONS preflight requests
    location /api {
        # CORS headers - allow from frontend domain
        add_header 'Access-Control-Allow-Origin' 'https://nodes.enclave-hq.com' always;
        add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD' always;
        add_header 'Access-Control-Allow-Headers' 'Origin, Content-Type, Content-Length, Accept-Encoding, X-CSRF-Token, Authorization, Cache-Control, Accept' always;
        add_header 'Access-Control-Allow-Credentials' 'true' always;
        add_header 'Access-Control-Expose-Headers' 'Content-Length, Content-Type, Authorization' always;
        add_header 'Access-Control-Max-Age' '86400' always;

        # Handle preflight requests
        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin' 'https://nodes.enclave-hq.com' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD' always;
            add_header 'Access-Control-Allow-Headers' 'Origin, Content-Type, Content-Length, Accept-Encoding, X-CSRF-Token, Authorization, Cache-Control, Accept' always;
            add_header 'Access-Control-Allow-Credentials' 'true' always;
            add_header 'Access-Control-Max-Age' '86400' always;
            add_header 'Content-Type' 'text/plain; charset=utf-8';
            add_header 'Content-Length' 0;
            return 204;
        }

        # Proxy to backend service
        # If backend is in Docker, use: http://127.0.0.1:4000
        # If backend is in Docker Compose network, use: http://backend:4000
        # If backend is on another server, use: http://backend-ip:4000
        proxy_pass http://127.0.0.1:4000;
        
        # Proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # Timeouts (important for long-running requests)
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        # Don't hide backend CORS headers - let backend handle CORS
        # But we also add our own for redundancy
        # proxy_hide_header Access-Control-Allow-Origin;
    }

    # Health check endpoint
    location /health {
        proxy_pass http://127.0.0.1:4000/health;
        proxy_set_header Host $host;
        access_log off;
    }

    # Root location - return 404 for non-API requests
    location / {
        return 404;
    }
}



















